# Wallet Solana (private key em base58, mantido secreto!)
WALLET_PRIVATE_KEY=your_private_key_here

# APIs
BIRDEYE_API_KEY=your_birdeye_api_key_here   # opcional: fallback OHLCV se Bitquery ausente
BITQUERY_API_KEY=your_bitquery_api_key_here # OHLCV (principal). Preço: Jupiter (grátis). Volume/liquidez: DexScreener (grátis)
# Delay (s) após detectar token — Bitquery leva 3-8 min para indexar (300 = 5 min)
BIRDEYE_DELAY_SECONDS=300
# Market cap mínimo (SOL) — tokens >55 SOL indexados mais rápido
MIN_MARKET_CAP_SOL=60
# Re-scan (s) entre tentativas — 120 economiza API e permite mais candles
RESCAN_DELAY_SECONDS=120
# Anti-clone: ignorar mesmo symbol por N segundos (evita spam)
ANTI_CLONE_SYMBOL_SECONDS=600
# Mínimo candles para análise (4 = entrada no pump inicial)
MIN_CANDLES=4
# Máximo tentativas por token (1 inicial + rescans)
MAX_RESCAN_ATTEMPTS=4
# Padrão: picos/valles mínimos (1=permissivo, 2=conservador)
MIN_PATTERN_STEPS=1
# Volume: último candle >= X da média (0.2 = 20%)
PATTERN_VOLUME_MIN_RATIO=0.2
# Ignorar checagem de volume (true = mais entradas, volume memecoins é caótico)
PATTERN_SKIP_VOLUME_CHECK=true
# Score mínimo para sinal (40=agressivo, 50=conservador)
MIN_SCORE=40

# Telegram alerts (opcional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Risk parameters (baseado em banca de ~$50)
MAX_POSITION_SIZE_USD=2.0          # Max $ por trade (usado se MAX_POSITION_SIZE_SOL=0)
MAX_POSITION_SIZE_SOL=0.01         # Max SOL por trade (prioridade; 0.01 SOL ≈ $2)
STOP_LOSS_PERCENT=20.0             # Stop loss %
TAKE_PROFIT_PERCENT1=100.0         # TP parcial 1 (50% da posição)
TAKE_PROFIT_PERCENT2=300.0         # TP final (50% restante)
MAX_HOLDING_MINUTES=30             # Max tempo de posição
MAX_CONCURRENT_POSITIONS=3         # Max posições simultâneas
MAX_DAILY_LOSS_USD=10.0            # Limite diário de perda

# PumpPortal endpoints
PUMP_PORTAL_WS=wss://pumpportal.fun/api/data
PUMP_PORTAL_API=https://pumpportal.fun/api/trade-local

# RPC Solana (usado com trade-local para assinar e enviar a transação)
# Preferir Helius: defina HELIUS_RPC (URL completa) ou HELIUS_API_KEY para menos 429 e melhor inclusão
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=
HELIUS_RPC=

# Slippage padrão (%) para compra/venda; 40 = melhor pagar taxa do que perder a entrada
DEFAULT_SLIPPAGE=40
# Nível de priority fee Helius: Min, Low, Medium, High, VeryHigh, UnsafeMax
PRIORITY_FEE_LEVEL=high
# Intervalo (s) entre checagens de preço no monitoramento (Jupiter); 15 economiza créditos
MONITOR_PRICE_INTERVAL_SECONDS=15
# Ao iniciar: vender tokens na carteira fora de positions.json (resíduos). false = desativado
AUTO_CLEANUP_ON_STARTUP=false

# Environment
ENVIRONMENT=production
DRY_RUN=true                       # Se true, só simula (não executa trades)

# Redis (cache)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=INFO