# Wallet Solana (private key em base58, mantido secreto!)
WALLET_PRIVATE_KEY=your_private_key_here

# APIs
# Birdeye: plano básico esgota rápido em /defi/ohlcv (compute units). Para operar só Bitquery + fontes grátis:
#   BIRDEYE_OHLCV_ENABLED=false  e deixe BIRDEYE_API_KEY vazio (ou só use a key noutro serviço no futuro).
# OHLCV recomendado: Bitquery (cota diária) + CandleBuilder (DexScreener, grátis) + USE_LOCAL_OHLC_FALLBACK opcional.
BIRDEYE_API_KEY=your_birdeye_api_key_here   # opcional; sem key = sem token_overview Birdeye nem OHLCV Birdeye
BIRDEYE_OHLCV_ENABLED=true                  # false = nunca chama Birdeye /defi/ohlcv (poupa compute units)
BITQUERY_API_KEY=your_bitquery_api_key_here   # OHLCV on-chain; precisa billing ativo (evita 402)

# Delay (s) após detectar token — Bitquery indexa em ~60s (muito mais rápido que os 300s do Birdeye)
# Se usar apenas Birdeye sem Bitquery, considere aumentar para 180-300
BIRDEYE_DELAY_SECONDS=60

# Market cap mínimo (SOL) — filtra tokens muito instáveis; 50 SOL é o mínimo recomendado
MIN_MARKET_CAP_SOL=50

# Re-scan (s) entre tentativas — 120 economiza API e permite mais candles
RESCAN_DELAY_SECONDS=120

# Anti-clone: ignorar mesmo symbol por N segundos (evita spam)
ANTI_CLONE_SYMBOL_SECONDS=600

# Mínimo candles para análise (4 = confirmação mínima antes de entrar)
MIN_CANDLES=4

# Máximo tentativas por token (1 inicial + rescans)
MAX_RESCAN_ATTEMPTS=4

# Padrão: picos/valles mínimos (1=permissivo, 2=conservador)
MIN_PATTERN_STEPS=1

# Volume: último candle >= X da média (0.2 = 20%)
PATTERN_VOLUME_MIN_RATIO=0.2

# Ignorar checagem de volume (true = mais entradas; volume memecoins é caótico)
PATTERN_SKIP_VOLUME_CHECK=true

# Score mínimo para sinal (40=agressivo, 60=conservador)
MIN_SCORE=60

# Telegram alerts (opcional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Risk parameters
MAX_POSITION_SIZE_USD=2.0          # Max $ por trade (usado se MAX_POSITION_SIZE_SOL=0)
MAX_POSITION_SIZE_SOL=0.01         # Max SOL por trade (prioridade; 0.01 SOL ≈ $2)
STOP_LOSS_PERCENT=20.0             # Stop loss % (20 = corta rápido; 30 segura muito e amplia perdas)
TAKE_PROFIT_PERCENT1=50.0          # TP parcial 1 (50% da posição vendida)
TAKE_PROFIT_PERCENT2=200.0         # TP final (restante da posição)
# Buffer TP1: reduz threshold para garantir que pega o movimento (0.8 = dispara a 40% se TP1=50%)
TAKE_PROFIT_BUFFER=0.8
MAX_HOLDING_MINUTES=30             # Max tempo de posição
MAX_CONCURRENT_POSITIONS=3         # Max posições simultâneas
MAX_DAILY_LOSS_USD=10.0            # Limite diário de perda (em $)

# PumpPortal endpoints
PUMP_PORTAL_WS=wss://pumpportal.fun/api/data
PUMP_PORTAL_API=https://pumpportal.fun/api/trade-local

# RPC Solana (obrigatório para trade-local: assinar e enviar transação)
# Preferir Helius: menos 429 e melhor inclusão de transações em memecoins
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=
HELIUS_RPC=                        # URL completa, ex: https://mainnet.helius-rpc.com/?api-key=XXX

# Slippage padrão (%) na compra; com slippage dinâmico (Fase 2) este valor é fallback
DEFAULT_SLIPPAGE=15
# Tiers de slippage dinâmico por liquidez (Fase 2)
SLIPPAGE_TIER_LOW=25.0             # liq < $5k
SLIPPAGE_TIER_MID=15.0             # liq $5k-$30k
SLIPPAGE_TIER_HIGH=10.0            # liq > $30k

# Entry conservador: infla entry_price com o slippage para SL/TP refletirem custo real
# DESLIGADO por padrão — inflar o entry atrasava o SL causando perdas maiores (-53% vs -20% target)
USE_CONSERVATIVE_ENTRY=false

# Filtro anti-entrada-no-topo: rejeita token se o preço atual (DexScreener) já subiu mais que
# X% acima do último preço do OHLCV analisado. Evita comprar após o pump ter ocorrido durante
# o delay de 60-120s do Bitquery. Não se aplica ao CandleBuilder (já é quase real-time).
# 0 = desabilitado; 50 = rejeita se preço subiu >50% desde a análise OHLCV.
MAX_ENTRY_PUMP_PERCENT=50

# Nível de priority fee Helius (Min, Low, Medium, High, VeryHigh, UnsafeMax)
PRIORITY_FEE_LEVEL=veryHigh

# Fallback de priority fee se não usar Helius (0.001 SOL ≈ $0.15, competitivo)
PRIORITY_FEE_FALLBACK_SOL=0.001

# Intervalo (s) entre checagens de preço no monitoramento
# 3s = mais rápido para capturar SL em crashes súbitos; 5s causava SL a -35%/-59% vs -20% target
MONITOR_PRICE_INTERVAL_SECONDS=3

# Emergency sell: se pnl cair STOP_LOSS + EMERGENCY % em um tick, vende com slippage 50%
EMERGENCY_SELL_THRESHOLD=15.0

# Retry de compra em timeout: reenviar com priority_fee +50% para garantir inclusão
BUY_RETRY_ON_TIMEOUT=true

# Ao iniciar: vender tokens na carteira fora de positions.json (resíduos de sessões anteriores)
AUTO_CLEANUP_ON_STARTUP=false

# Fase 1 — CandleBuilder (constrói OHLCV em tempo real via DexScreener, sem esperar Bitquery)
USE_REALTIME_CANDLES=false
CANDLE_TIMEFRAME_SECONDS=15        # Duração de cada candle em segundos
CANDLE_BUILD_TIMEOUT_SECONDS=90    # Tempo total de coleta antes de analisar
# Quando Bitquery falha ou CandleBuilder insuficiente: candles “flat” a partir do preço DexScreener (não substitui histórico real)
USE_LOCAL_OHLC_FALLBACK=false
LOCAL_OHLC_CANDLES=3
LOCAL_OHLC_CANDLE_INTERVAL_SECONDS=60

# Fase 1 — RugCheck (score de risco antes de consumir quota do Bitquery; free tier)
RUGCHECK_ENABLED=false
RUGCHECK_MIN_SCORE=500

# Fase 1 — Alertas de inatividade e heartbeat
NO_TOKEN_ALERT_SECONDS=300         # Alerta Telegram se nenhum token novo em X segundos
HEARTBEAT_INTERVAL_MINUTES=30      # Alerta Telegram periódico "bot vivo"

# Fase 2 — Jito Bundles (proteção MEV; desabilitado por padrão)
USE_JITO=false
JITO_TIP_LAMPORTS=50000

# Fase 3 — Fila de prioridade por market_cap
TOKEN_QUEUE_WORKERS=3              # Workers paralelos processando tokens da fila
TOKEN_QUEUE_MAX_AGE_SECONDS=600    # Token descartado se aguardar mais que X segundos na fila

# Environment
ENVIRONMENT=production
DRY_RUN=true                       # Se true, só simula (não executa trades reais)

# Redis (cache de daily_loss e posições — opcional)
REDIS_URL=redis://localhost:6379

# PostgreSQL (Railway ou local) — quando definido, posições e histórico usam o DB
# Ex.: DATABASE_URL=postgresql://user:pass@host:5432/railway
# DATABASE_URL=

# Logging
LOG_LEVEL=INFO
